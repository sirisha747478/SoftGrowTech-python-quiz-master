rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: leaderboard
    // Document ID: auto-generated
    // Fields:
    //   - uid: string (required) - The user ID of the player
    //   - displayName: string (required) - The display name of the player
    //   - score: number (required) - The score achieved
    //   - difficulty: string (required, enum: EASY, MEDIUM, HARD) - The difficulty level
    //   - createdAt: timestamp (required) - The time the score was recorded
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['uid', 'displayName', 'score', 'difficulty', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'displayName', 'score', 'difficulty', 'createdAt']) &&
             data.uid is string && data.uid == request.auth.uid &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 50 &&
             data.score is number && data.score >= 0 &&
             data.difficulty in ['EASY', 'MEDIUM', 'HARD'] &&
             data.createdAt is timestamp;
    }

    match /leaderboard/{entryId} {
      allow read: if true; // Public leaderboard
      allow create: if isAuthenticated() && isValidLeaderboardEntry(request.resource.data);
      allow update, delete: if false; // Scores are immutable
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
